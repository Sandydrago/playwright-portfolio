{
  "envName": "dev",
  "ui": {
    "baseURL": "http://localhost:3000"
  },
  "api": {
    "baseURL": "http://localhost:8000",
    "auth": {
      "login": "/auth/login",
      "refresh": "/auth/refresh"
    },
    "users": {
      "getUser": "/users/{id}",
      "listUsers": "/users"
    }
  },
  "timeouts": {
    "apiTimeout": 5000,
    "uiTimeout": 10000
  },
  "featureFlags": {
    "enableBetaFeatures": true
  }
}
